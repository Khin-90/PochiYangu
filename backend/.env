# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Database settings (PostgreSQL example)
DATABASE_NAME=pochiyangu_db
DATABASE_USER=pochiyangu_user
DATABASE_PASSWORD=your-db-password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Email settings (for sending emails)
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True

# CORS settings (for React frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Sui blockchain settings (for future integration)
SUI_NETWORK_URL=https://fullnode.devnet.sui.io:443
SUI_WALLET_ADDRESS=your-sui-wallet-address
SUI_PRIVATE_KEY=your-sui-private-key